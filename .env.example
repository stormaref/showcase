# --- Shared ---
APP_ENV=development
DOMAIN=localhost

# --- PostgreSQL ---
POSTGRES_USER=showcase
POSTGRES_PASSWORD=showcase_dev_password
POSTGRES_DB=showcase
DATABASE_URL=postgres://showcase:showcase_dev_password@localhost:5432/showcase?sslmode=disable

# --- MinIO ---
MINIO_ROOT_USER=showcase_minio
MINIO_ROOT_PASSWORD=showcase_minio_password
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=showcase_minio
MINIO_SECRET_KEY=showcase_minio_password
MINIO_BUCKET=showcase-media
MINIO_USE_SSL=false
MEDIA_PUBLIC_BASE_URL=http://localhost:9000/showcase-media

# --- API (service/) ---
API_HOST=0.0.0.0
API_PORT=8080
JWT_ACCESS_SECRET=change-me-access-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars-long!
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
CORS_ORIGINS=http://localhost:3000,http://admin.localhost:3000
COOKIE_DOMAIN=localhost
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-on-first-login
MAX_UPLOAD_MB=10
RATE_LIMIT_PER_MINUTE=100
LOGIN_RATE_LIMIT_PER_MINUTE=5

# --- Web (webapp/) ---
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_MEDIA_BASE_URL=http://localhost:9000/showcase-media
NEXT_PUBLIC_SITE_URL=http://localhost:3000
INTERNAL_API_URL=http://localhost:8080

# --- Docker ---
WEB_DOCKER_TARGET=dev
# WEB_DOCKER_TARGET=runner   # use for prod profile

# --- Production (compose profile prod) ---
# DOMAIN=example.com
# ACME_EMAIL=you@example.com
# GHCR_IMAGE_API=ghcr.io/stormaref/showcase-api:latest
# GHCR_IMAGE_WEB=ghcr.io/stormaref/showcase-web:latest
